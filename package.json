{
  "name": "passing-notes-rxdb",
  "version": "0.0.0",
  "description": "An HTTP replication middleware for RxDB that persists to SQLite",
  "keywords": [
    "rxdb",
    "replication",
    "sqlite"
  ],
  "homepage": "https://github.com/vinsonchuong/passing-notes-rxdb",
  "bugs": "https://github.com/vinsonchuong/passing-notes-rxdb/issues",
  "license": "MIT",
  "author": "Vinson Chuong <vinsonchuong@gmail.com>",
  "repository": "vinsonchuong/passing-notes-rxdb",
  "type": "module",
  "exports": {
    ".": "./index.js",
    "./sqlite": "./lib/persistence/sqlite.js",
    "./client": "./lib/client.js"
  },
  "scripts": {
    "test": "xo && ava",
    "release": "semantic-release"
  },
  "packageManager": "yarn@4.13.0",
  "dependencies": {
    "rxdb": "^16.21.1",
    "rxjs": "^7.8.2"
  },
  "peerDependencies": {
    "better-sqlite3": "^12.6.2",
    "passing-notes": "^6.8.6"
  },
  "devDependencies": {
    "ava": "^7.0.0",
    "ava-patterns": "^3.2.1",
    "better-sqlite3": "^12.6.2",
    "eventsource": "^4.1.0",
    "passing-notes": "^6.8.6",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3",
    "xo": "^1.2.3"
  },
  "ava": {
    "verbose": true,
    "timeout": "3m"
  },
  "xo": {
    "prettier": true,
    "space": 2,
    "semicolon": false,
    "rules": {
      "complexity": "off",
      "no-await-in-loop": "off",
      "import/no-anonymous-default-export": "off",
      "unicorn/prevent-abbreviations": "off",
      "unicorn/no-process-exit": "off"
    }
  },
  "release": {
    "branches": [
      "main"
    ]
  }
}
